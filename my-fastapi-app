@app.post("/api/swarm/analyze")
async def analyze_swarm_state(identity_id: str):
    """Analyze the current state of a swarm"""
    if identity_id not in identities_db:
        raise HTTPException(status_code=404, detail="Identity not found")
    
    identity = identities_db[identity_id]
    active_routines = [r for r in routines_db.values() if r.identity_id == identity_id]
    active_directives = [d for d in directives_db.values() 
                        if d.identity_id == identity_id and d.status != "completed"]
    
    # Get AI analysis
    ai_engine = await get_ai_engine()
    analysis = await ai_engine.analyze_swarm_performance(
        identity.dict(),
        [r.dict() for r in active_routines],
        [d.dict() for d in active_directives]
    )
    
    return {
        "identity": identity.name,
        "status": identity.status,
        "active_routines": len(active_routines),
        "active_directives": len(active_directives),
        "system_health": "optimal",
        "ai_analysis": analysis,
        "timestamp": datetime.utcnow().isoformat()
    }


