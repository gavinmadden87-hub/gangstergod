# ============================================================================
# Data Models - The Identity Stack Architecture
# ============================================================================

class IdentityStatus(str, Enum):
    """Status of an identity stack"""
    ACTIVE = "active"
    DORMANT = "dormant"
    EVOLVING = "evolving"
    LOCKED = "locked"


class IdentityStack(BaseModel):
    """Core identity definition for Gangster God operators"""
    id: str = Field(..., description="Unique identifier for this identity stack")
    name: str = Field(..., description="Name of the identity/persona")
    philosophy: str = Field(..., description="Core philosophy and principles")
    disciplines: List[str] = Field(default_factory=list, description="Key disciplines to master")
    status: IdentityStatus = Field(default=IdentityStatus.ACTIVE)
    created_at: datetime = Field(default_factory=datetime.utcnow)
    updated_at: datetime = Field(default_factory=datetime.utcnow)


class Routine(BaseModel):
    """Daily/weekly routine for maintaining discipline"""
    id: str = Field(..., description="Unique identifier")
    identity_id: str = Field(..., description="Associated identity stack")
    name: str = Field(..., description="Routine name")
    description: str = Field(..., description="What this routine accomplishes")
    frequency: str = Field(..., description="daily, weekly, monthly")
    tasks: List[str] = Field(default_factory=list, description="Individual tasks")
    created_at: datetime = Field(default_factory=datetime.utcnow)


class StrategicDirective(BaseModel):
    """High-level strategic command for the swarm"""
    id: str = Field(..., description="Unique identifier")
    identity_id: str = Field(..., description="Associated identity stack")
    title: str = Field(..., description="Directive title")
    objective: str = Field(..., description="What needs to be accomplished")
    priority: int = Field(default=5, ge=1, le=10, description="Priority level 1-10")
    status: str = Field(default="pending", description="pending, in_progress, completed")
    created_at: datetime = Field(default_factory=datetime.utcnow)
    updated_at: datetime = Field(default_factory=datetime.utcnow)


class BillingStat(BaseModel):
    """Billing statistics for revenue tracking"""
    label: str
    revenue: float


class BillingStatsResponse(BaseModel):
    """Complete billing statistics response"""
    totalRevenue: float
    mrr: float
    points: List[BillingStat]


