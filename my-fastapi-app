@app.get("/api/identities", response_model=List[IdentityStack])
async def list_identities():
    """Retrieve all identity stacks"""
    return list(identities_db.values())


@app.get("/api/identities/{identity_id}", response_model=IdentityStack)
async def get_identity(identity_id: str):
    """Retrieve a specific identity stack"""
    if identity_id not in identities_db:
        raise HTTPException(status_code=404, detail="Identity not found")
    return identities_db[identity_id]


@app.post("/api/identities", response_model=IdentityStack)
async def create_identity(identity: IdentityStack):
    """Create a new identity stack"""
    if identity.id in identities_db:
        raise HTTPException(status_code=400, detail="Identity already exists")
    identities_db[identity.id] = identity
    return identity


@app.put("/api/identities/{identity_id}", response_model=IdentityStack)
async def update_identity(identity_id: str, identity: IdentityStack):
    """Update an existing identity stack"""
    if identity_id not in identities_db:
        raise HTTPException(status_code=404, detail="Identity not found")
    identity.updated_at = datetime.utcnow()
    identities_db[identity_id] = identity
    return identity


