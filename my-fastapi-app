        id=f"directive-{len(directives_db) + 1}",
        identity_id=identity_id,
        title=directive_data.get("title", "AI-Generated Directive"),
        objective=directive_data.get("objective", challenge),
        priority=directive_data.get("priority", 5),
        status="pending"
    )
    directives_db[new_directive.id] = new_directive
    
    return {
        "directive": new_directive,
        "execution_steps": directive_data.get("execution_steps", []),
        "generated_at": datetime.utcnow().isoformat()
